{
  "name": "skein",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5890",
    "build": "vite build",
    "build:cloudflare": "vite build --config vite.standalone.config.ts",
    "dev:tauri": "VITE_TAURI=1 vite --config vite.standalone.config.ts --port 5891 --strictPort",
    "build:tauri": "VITE_TAURI=1 vite build --config vite.standalone.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:report": "open coverage/html/index.html",
    "lint": "eslint src widgets --ext .ts",
    "lint:fix": "eslint src widgets --ext .ts --fix",
    "lint:circular": "npx madge --circular --extensions ts src/ widgets/",
    "ts-prune": "ts-prune",
    "check": "npm run typecheck && npm run lint && npm run lint:circular && npm run test:all"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@automerge/automerge-repo": "^2.5.6",
    "@automerge/automerge-repo-network-broadcastchannel": "^2.5.6",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.6",
    "@pixi/ui": "^2.3.2",
    "comlink": "^4.4.2",
    "midden": "file:../midden/pkg",
    "pixi.js": "^8.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "prettier": "^3.9.4",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.9"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "printWidth": 100,
    "tabWidth": 2
  }
}
