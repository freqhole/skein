{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skein",
  "version": "0.1.0",
  "identifier": "net.freqhole.skein",
  "build": {
    "beforeDevCommand": {
      "cwd": "../loam",
      "script": "npm run dev:tauri"
    },
    "devUrl": "http://localhost:5891",
    "beforeBuildCommand": {
      "cwd": "../loam",
      "script": "npm run build:tauri"
    },
    "frontendDist": "../loam/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "skein",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "settings",
        "title": "skein settings",
        "url": "settings.html",
        "width": 520,
        "height": 480,
        "minWidth": 360,
        "minHeight": 320,
        "resizable": true,
        "visible": false,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
